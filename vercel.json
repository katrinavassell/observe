{
  "buildCommand": "npm run build",
  "outputDirectory": "dist",
  "framework": "vite",
  "ignoreCommand": "if [ \"$VERCEL_GIT_COMMIT_REF\" = \"main\" ]; then exit 1; else exit 0; fi",
  "functions": {
    "api/index.ts": {
      "maxDuration": 30,
      "includeFiles": "server/**"
    },
    "api/cron/weekly-digest.ts": {
      "maxDuration": 60,
      "includeFiles": "server/**"
    },
    "api/cron/posthog-audit.ts": {
      "maxDuration": 120,
      "includeFiles": "server/**"
    }
  },
  "crons": [
    {
      "path": "/api/cron/weekly-digest",
      "schedule": "0 14 * * 0"
    },
    {
      "path": "/api/cron/posthog-audit",
      "schedule": "0 12 * * *"
    }
  ],
  "rewrites": [
    { "source": "/api/cron/(.*)", "destination": "/api/cron/$1" },
    { "source": "/api/(.*)", "destination": "/api" },
    { "source": "/((?!api).*)", "destination": "/index.html" }
  ]
}
