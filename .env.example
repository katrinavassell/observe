# =============================================================================
# Required -- app will not start without these
# =============================================================================
DATABASE_URL=postgresql://user:pass@host/dbname?sslmode=require
SESSION_SECRET=generate-a-random-64-char-hex-string

# =============================================================================
# Tanso billing (optional -- all features unlocked if not set)
# =============================================================================
TANSO_API_KEY=
TANSO_ACCOUNT_ID=
# TANSO_MCP_URL=https://api.tansohq.com/mcp

# =============================================================================
# Stripe (optional -- checkout and customer portal disabled if not set)
# =============================================================================
STRIPE_SECRET_KEY=
STRIPE_PUBLISHABLE_KEY=

# =============================================================================
# AI provider keys (optional -- proxy mode and AI suggestions disabled if not set)
# =============================================================================
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# =============================================================================
# Email alerts via Resend (optional -- alerts created but never sent if not set)
# =============================================================================
RESEND_API_KEY=
# ALERT_FROM_EMAIL=alerts@tansohq.com
# APP_URL=https://yourdomain.com

# =============================================================================
# Model pricing refresh (optional -- uses seed data if not set)
# =============================================================================
# OPENROUTER_API_KEY=

# =============================================================================
# Deployment / runtime
# =============================================================================
# NODE_ENV=production
# PORT=3001
# DB_DRIVER=pg
# ALLOWED_ORIGINS=https://yourdomain.com
# ADMIN_EMAILS=admin@example.com
