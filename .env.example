# =============================================================================
# Required -- app will not start without these
# =============================================================================
DATABASE_URL=postgresql://postgres.[ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=sbp_...

# Frontend (Vite exposes these to the browser)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=sb_publishable_...

# =============================================================================
# Stripe billing (optional -- all features unlocked if not set)
# =============================================================================
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_GROWTH_PRICE_ID=price_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_WEBHOOK_SECRET=whsec_...

# =============================================================================
# AI provider keys (optional -- proxy mode and AI suggestions disabled if not set)
# =============================================================================
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# =============================================================================
# Email alerts via Resend (optional -- alerts created but never sent if not set)
# =============================================================================
RESEND_API_KEY=
# ALERT_FROM_EMAIL=alerts@yourdomain.com
# APP_URL=https://yourdomain.com

# =============================================================================
# Model pricing refresh (optional -- uses seed data if not set)
# =============================================================================
# OPENROUTER_API_KEY=

# =============================================================================
# Security (required in production -- dev fallback used when NODE_ENV=development)
# =============================================================================
# INTEGRATION_ENCRYPTION_KEY=generate-a-random-32-char-string

# =============================================================================
# Deployment / runtime
# =============================================================================
# NODE_ENV=production
# PORT=3001
# ALLOWED_ORIGINS=https://yourdomain.com
# ADMIN_EMAILS=admin@example.com
