# =============================================================================
# Required -- app will not start without these
# =============================================================================
DATABASE_URL=postgresql://user:password@host:5432/dbname
# PG_POOL_MAX=8          # Connection pool size (default 8). Use a pooler URL for Neon/Supabase serverless.

# Clerk auth
CLERK_SECRET_KEY=sk_test_...
VITE_CLERK_PUBLISHABLE_KEY=pk_test_...

# =============================================================================
# Stripe billing (optional -- all features unlocked if not set)
# =============================================================================
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_GROWTH_PRICE_ID=price_...
STRIPE_PRO_PRICE_ID=price_...
STRIPE_WEBHOOK_SECRET=whsec_...

# =============================================================================
# AI provider keys (optional -- proxy mode and AI suggestions disabled if not set)
# =============================================================================
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# =============================================================================
# Email alerts via Resend (optional -- alerts created but never sent if not set)
# =============================================================================
RESEND_API_KEY=
# ALERT_FROM_EMAIL=alerts@yourdomain.com
# APP_URL=https://yourdomain.com

# =============================================================================
# Model pricing refresh (optional -- uses seed data if not set)
# =============================================================================
# OPENROUTER_API_KEY=

# =============================================================================
# Security (REQUIRED -- server will refuse to start without this)
# =============================================================================
# Encrypts stored provider API keys (OpenAI, Anthropic, Stripe, etc.) at rest.
# Must be at least 16 characters. Generate one with: openssl rand -hex 32
INTEGRATION_ENCRYPTION_KEY=

# Session secret for Express sessions. Must be at least 32 characters.
# Generate with: openssl rand -hex 32
SESSION_SECRET=

# =============================================================================
# Deployment / runtime
# =============================================================================
# NODE_ENV=production
# PORT=3001
# ALLOWED_ORIGINS=https://yourdomain.com
# ADMIN_EMAILS=admin@example.com
